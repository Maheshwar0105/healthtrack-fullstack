# HealthTrack Backend Configuration Example

# Server settings
PORT=5000
NODE_ENV=production

# Database Connection (MongoDB Atlas URI)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Security (JWT configuration)
JWT_SECRET=your_jwt_access_token_secret_minimum_32_characters
JWT_REFRESH_SECRET=your_jwt_refresh_token_secret_minimum_32_characters

# Real-Time Features (Socket.io)
ENABLE_SOCKETIO=true

# Frontend client URL (CORS origin)
FRONTEND_URL=https://your-netlify-app-url.netlify.app

# Third-Party API integrations
# Mapbox token (for reverse geocoding inside API services)
MAPBOX_TOKEN=pk.eyJ1Ijo...

# Google Gemini API key (for diet plans, workout routine generation, and weekly reports)
GEMINI_API_KEY=AIzaSy...

# Optional SMTP Settings (Default to mock transporter if left blank)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="HealthTrack Pro" <no-reply@healthtrack.com>
