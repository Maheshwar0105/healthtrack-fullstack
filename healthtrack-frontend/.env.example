# HealthTrack Frontend Configuration Example

# Base API URL of your deployed Express backend
VITE_API_URL=https://your-backend-railway-url.railway.app/api

# WebSocket URL of your deployed Express backend (omit trailing slash)
VITE_SOCKET_URL=https://your-backend-railway-url.railway.app

# Mapbox Access Token (required for displaying maps, routes, and activity markers)
VITE_MAPBOX_TOKEN=pk.eyJ1Ijo...
